# Rename this file to .env and fill in your API keys.

# VirusTotal API v3 - https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# AlienVault OTX - https://otx.alienvault.com/api
OTX_API_KEY=

# abuse.ch ThreatFox - https://threatfox.abuse.ch/api/
THREATFOX_API_KEY=

# AbuseIPDB (IP lookups only) - https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# abuse.ch URLhaus (URL lookups only) - public API, key optional (raises rate limit)
URLHAUS_API_KEY=

# abuse.ch MalwareBazaar (hash lookups only) - public API, no key required
MALWAREBAZAAR_API_KEY=


# Pulsedive (IP / domain / URL reputation) - free API key from https://pulsedive.com/api/
PULSEDIVE_API_KEY=
